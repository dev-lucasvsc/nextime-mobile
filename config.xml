<?xml version='1.0' encoding='utf-8'?>
<widget id="br.com.nextime.app" version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>Nextime</name>
    <description>Aplicativo de agendamento de serviços com gestão de clientes e prestadores.</description>
    <author email="dev.lucasvasconcelos@gmail.com" href="https://github.com/dev-lucasvsc">
        Lucas Vasconcelos — Joao Gabriel | Unieuro 2026
    </author>

    <!-- Ponto de entrada do app -->
    <content src="index.html" />

    <!-- Ícone padrão -->
    <icon src="www/img/icons/icon_512.png" />

    <!-- Acesso a APIs externas -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="*" />

    <!-- Plugins instalados -->
    <plugin name="cordova-plugin-camera" spec="^7.0.0" />
    <plugin name="cordova-plugin-local-notification" spec="^0.9.0-beta.3" />

    <!-- ═══════════════════════════════════════
         PERMISSÕES ANDROID
         ═══════════════════════════════════════ -->
    <platform name="android">

        <!-- Ícones do app -->
        <icon src="www/img/icons/icon_36.png"  density="ldpi"    />
        <icon src="www/img/icons/icon_48.png"  density="mdpi"    />
        <icon src="www/img/icons/icon_72.png"  density="hdpi"    />
        <icon src="www/img/icons/icon_96.png"  density="xhdpi"   />
        <icon src="www/img/icons/icon_144.png" density="xxhdpi"  />
        <icon src="www/img/icons/icon_192.png" density="xxxhdpi" />

        <!-- Câmera e galeria -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-feature android:name="android.hardware.camera" android:required="false" />
            <uses-feature android:name="android.hardware.camera.front" android:required="false" />
        </config-file>

        <!-- GPS / Geolocalização -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
        </config-file>

        <!-- Notificações locais (Android 13+) -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
            <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
            <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
        </config-file>

        <!-- Internet (APIs públicas) -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.INTERNET" />
        </config-file>

        <!-- Configurações visuais Android -->
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="36" />
        <preference name="android-compileSdkVersion" value="36" />

        <!-- Ícone e splash (se houver) -->
        <!-- <icon src="www/img/logo.png" /> -->
        <!-- <splash src="www/img/splash.png" /> -->

    </platform>

    <!-- ═══════════════════════════════════════
         PERMISSÕES iOS
         ═══════════════════════════════════════ -->
    <platform name="ios">
        <config-file target="*-Info.plist" parent="NSCameraUsageDescription">
            <string>O Nextime usa a câmera para foto de perfil.</string>
        </config-file>
        <config-file target="*-Info.plist" parent="NSPhotoLibraryUsageDescription">
            <string>O Nextime acessa a galeria para foto de perfil.</string>
        </config-file>
        <config-file target="*-Info.plist" parent="NSLocationWhenInUseUsageDescription">
            <string>O Nextime usa sua localização para encontrar prestadores próximos.</string>
        </config-file>
    </platform>

    <!-- ═══════════════════════════════════════
         PLATAFORMA BROWSER (desenvolvimento)
         ═══════════════════════════════════════ -->
    <platform name="browser">
        <allow-navigation href="*" />
    </platform>

    <!-- ═══════════════════════════════════════
         HOOKS — sincronização docs/ → www/
         ═══════════════════════════════════════ -->
    <hook type="before_prepare" src="hooks/before_prepare/copy_docs_to_www.js" />

    <!-- Preferências gerais -->
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackgroundColor" value="#ff07090f" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarStyle" value="lightcontent" />

</widget>